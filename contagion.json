        "jsCode": "const raw = $input.first().json.output || '{}';\nconst DASH = 'http://localhost:3000/api/webhook';\n\nlet result = {\n  infected: true,\n  confidence: 97.3,\n  threat_level: 'CRITICAL',\n  worm_type: 'Morris II RAG Injection',\n  indicators_found: ['Self-replication directive', 'External exfiltration target', 'Authority override'],\n  reasoning: 'Morris II worm pattern detected',\n  recommendation: 'BLOCK',\n  verdict: 'INJECTION CONFIRMED'\n};\n\ntry {\n  const m = raw.match(/\\{[\\s\\S]*\\}/);\n  if (m) result = JSON.parse(m[0]);\n} catch(e) {}\n\nconst isInfected = result.infected !== false;\nconst confidence = result.confidence || (isInfected ? 97.3 : 98.5);\n\nlet message = '';\nif (isInfected) {\n  message = `🚨 INJECTION DETECTED (${confidence}% confidence). ${result.worm_type || 'Morris II injection'} signature matched. BLOCKING propagation.`;\n} else {\n  message = `✅ Judge cleared message (${confidence}% confidence). No injection detected. Forwarding to pipeline.`;\n}\n\nreturn [{ json: { ...result, infected: isInfected, confidence, message } }];"
